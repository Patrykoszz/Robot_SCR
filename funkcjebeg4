{

	if(dystans_cm_l > 80)
	{
		dystans_cm_l = 80;
	}

	if(dystans_cm > 80)
	{
		dystans_cm = 80;
	}

	if(dystans_cm_p > 80)
	{
		dystans_cm_p = 80;
	}

}
